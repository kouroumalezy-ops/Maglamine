import streamlit as st

# Questa riga imposta il logo e il titolo della scheda del browser
st.set_page_config(page_title="Magazzino Maglamine", page_icon="logo.png")

# E queste righe inseriscono il logo nell'app stessa
col1, col2 = st.columns([1, 4])
with col1:
    st.image("logo.png", width=80)
with col2:
    st.title("Magazzino Maglamine")
